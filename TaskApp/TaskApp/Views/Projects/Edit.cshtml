@model TaskApp.Models.Project
@using TaskApp.Models

@{
    ViewData["Title"] = "Edit Project";
    var users = ViewBag.Users as IEnumerable<User> ?? Enumerable.Empty<User>();
}

<h2>Edit Project</h2>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="OwnerId" class="form-label">Owner</label>
        <select asp-for="OwnerId" class="form-select">
            @foreach (var u in users)
            {
                <option value="@u.Id" selected="@(u.Id == Model.OwnerId)">@u.Name</option>
            }
        </select>
        <span asp-validation-for="OwnerId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>
