@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Dashboard</h2>
    <a asp-controller="Projects" asp-action="Create" class="btn btn-sm btn-outline-primary">+ New Project</a>
</div>

<div id="projects-container" class="row g-3">
    <div class="col-12 text-center text-muted py-5">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        Loading projects…
    </div>
</div>

@section Scripts {
<script>
(async function loadDashboard() {
    var res = await fetch('/api/dashboard');
    if (res.status === 401) { window.location.href = '/Account/Login'; return; }
    if (!res.ok) { renderError('Failed to load dashboard.'); return; }

    var projects = await res.json();
    renderProjects(projects);
})();

function renderProjects(projects) {
    var container = document.getElementById('projects-container');
    if (!projects.length) {
        container.innerHTML =
            '<div class="col-12 text-muted">No projects yet. <a href="/Projects/Create">Create one</a>.</div>';
        return;
    }
    container.innerHTML = projects.map(function(p) {
        return '<div class="col-sm-6 col-lg-4">' +
            '<div class="card h-100 shadow-sm">' +
            '<div class="card-body d-flex flex-column">' +
            '<h5 class="card-title">' + esc(p.projectName) + '</h5>' +
            '<p class="text-muted small mb-3">Total tasks: <strong>' + p.total + '</strong></p>' +
            '<div class="d-flex gap-2 flex-wrap mb-auto">' +
            '<span class="badge bg-secondary">Todo: ' + p.todo + '</span>' +
            '<span class="badge bg-primary">In&nbsp;Progress: ' + p.inProgress + '</span>' +
            '<span class="badge bg-success">Done: ' + p.done + '</span>' +
            '</div>' +
            '<a href="/Projects/View/' + p.projectId + '" class="btn btn-sm btn-outline-primary mt-3">View tasks</a>' +
            '</div></div></div>';
    }).join('');
}

function renderError(msg) {
    document.getElementById('projects-container').innerHTML =
        '<div class="col-12"><div class="alert alert-danger">' + esc(msg) + '</div></div>';
}

function esc(s) {
    return String(s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
</script>
}
